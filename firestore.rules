rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isRider() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'rider';
    }

    function isValidRole(value) {
      return value is string
        && ['admin', 'counter', 'rider', 'customer'].hasAny([value]);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function hasOnlyChangedKeys(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    function isValidLatLng(value) {
      return value is map
        && value.keys().hasOnly(['lat', 'lng'])
        && value.lat is number
        && value.lng is number;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && hasOnlyKeys(request.resource.data, [
          'name',
          'phone',
          'email',
          'role',
          'fcmTokens',
          'lastNotificationToken',
          'notificationPermissionStatus',
          'notificationsUpdatedAt'
        ])
        && (!('role' in request.resource.data)
          || isValidRole(request.resource.data.role)
          && request.resource.data.role == 'customer');
      allow update: if (isAdmin()
          && hasOnlyKeys(request.resource.data, [
            'name',
            'phone',
            'email',
            'role',
            'fcmTokens',
            'lastNotificationToken',
            'notificationPermissionStatus',
            'notificationsUpdatedAt'
          ])
          && (!('role' in request.resource.data)
            || isValidRole(request.resource.data.role)))
        || (isOwner(userId)
          && hasOnlyKeys(request.resource.data, [
            'name',
            'phone',
            'email',
            'role',
            'fcmTokens',
            'lastNotificationToken',
            'notificationPermissionStatus',
            'notificationsUpdatedAt'
          ])
          && !request.resource.data.diff(resource.data).changedKeys().hasAny(['role']));
      allow delete: if false;
    }

    match /meal_sessions/{sessionId} {
      allow read: if true;
      allow write: if isAdmin()
        && hasOnlyKeys(request.resource.data, [
          'name',
          'startHour',
          'startMinute',
          'endHour',
          'endMinute',
          'isActive'
        ]);
    }

    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin()
        && hasOnlyKeys(request.resource.data, [
          'name',
          'description',
          'price',
          'imageUrl',
          'localImageAsset',
          'categoryName',
          'mealSessionId',
          'isAvailable',
          'stock',
          'prepTimeMinutes'
        ]);
      allow update: if isSignedIn()
        && hasOnlyChangedKeys(['stock'])
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0
        && request.resource.data.stock <= resource.data.stock;
    }

    match /settings/{documentId} {
      allow read: if true;
      allow write: if isAdmin()
        && hasOnlyKeys(request.resource.data, [
          'businessName',
          'phone',
          'deliveryFee',
          'taxRate',
          'currency',
          'pickupEnabled',
          'orderingOpen',
          'openingHoursNote',
          'bannerMessage',
          'activeOffer'
        ]);
    }

    match /orders/{orderId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isRider() && resource.data.assignedRiderId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && hasOnlyKeys(request.resource.data, [
          'userId',
          'items',
          'subtotal',
          'deliveryFee',
          'total',
          'status',
          'mealSessionId',
          'deliveryType',
          'address',
          'deliveryLocation',
          'createdAt'
        ])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.status == 'pending'
        && request.resource.data.deliveryType in ['delivery', 'pickup']
        && request.resource.data.address is string
        && request.resource.data.createdAt is timestamp
        && (!(request.resource.data.deliveryLocation is map)
          || isValidLatLng(request.resource.data.deliveryLocation));
      allow update: if isAdmin()
        && hasOnlyChangedKeys([
          'status',
          'updatedAt',
          'assignedRiderId',
          'assignedRiderName',
          'assignedRiderEmail',
          'assignedAt'
        ]);
      allow delete: if false;
    }
  }
}
