rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidRole(value) {
      return value is string
        && ['admin', 'counter', 'rider', 'customer'].hasAny([value]);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function hasOnlyChangedKeys(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && hasOnlyKeys(request.resource.data, [
          'name',
          'phone',
          'email',
          'role',
          'fcmTokens',
          'lastNotificationToken',
          'notificationPermissionStatus',
          'notificationsUpdatedAt'
        ])
        && (!('role' in request.resource.data)
          || isValidRole(request.resource.data.role)
          && request.resource.data.role == 'customer');
      allow update: if (isAdmin()
          && hasOnlyKeys(request.resource.data, [
            'name',
            'phone',
            'email',
            'role',
            'fcmTokens',
            'lastNotificationToken',
            'notificationPermissionStatus',
            'notificationsUpdatedAt'
          ])
          && (!('role' in request.resource.data)
            || isValidRole(request.resource.data.role)))
        || (isOwner(userId)
          && hasOnlyKeys(request.resource.data, [
            'name',
            'phone',
            'email',
            'role',
            'fcmTokens',
            'lastNotificationToken',
            'notificationPermissionStatus',
            'notificationsUpdatedAt'
          ])
          && !request.resource.data.diff(resource.data).changedKeys().hasAny(['role']));
      allow delete: if false;
    }

    match /meal_sessions/{sessionId} {
      allow read: if true;
      allow write: if isAdmin()
        && hasOnlyKeys(request.resource.data, [
          'name',
          'startHour',
          'startMinute',
          'endHour',
          'endMinute',
          'isActive'
        ]);
    }

    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin()
        && hasOnlyKeys(request.resource.data, [
          'name',
          'description',
          'price',
          'imageUrl',
          'localImageAsset',
          'categoryName',
          'mealSessionId',
          'isAvailable',
          'stock',
          'prepTimeMinutes'
        ]);
    }

    match /settings/{documentId} {
      allow read: if true;
      allow write: if isAdmin()
        && hasOnlyKeys(request.resource.data, [
          'businessName',
          'phone',
          'deliveryFee',
          'taxRate',
          'currency',
          'pickupEnabled',
          'orderingOpen',
          'openingHoursNote',
          'bannerMessage',
          'activeOffer'
        ]);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if false;
      allow update: if isAdmin()
        && hasOnlyChangedKeys(['status', 'updatedAt']);
      allow delete: if false;
    }
  }
}
